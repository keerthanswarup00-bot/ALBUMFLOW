# =============================================================================
# ALBUMFLOW — Required Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Vercel), set these in your project dashboard:
#   https://vercel.com/YOUR-TEAM/albumflow/settings/environment-variables
# =============================================================================

# -- Supabase -----------------------------------------------------------------
# Find these in your Supabase project dashboard:
#   Project Settings → API → Project URL / anon public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
